{
  "name": "chat",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,vite -c blue,magenta \"bun run server\" \"vite\"",
    "server": "bun --watch server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "tsc -b --noEmit"
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.0",
    "@assistant-ui/react": "^0.12.0",
    "@assistant-ui/react-ai-sdk": "^1.3.0",
    "@openrouter/ai-sdk-provider": "^2.3.1",
    "ai": "^6.0.116",
    "hono": "^4.6.0",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
